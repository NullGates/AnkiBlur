+def _setup_macos_vibrancy(window):
+    """Apply NSVisualEffectView under the Qt content view (AnkiBlur).
+
+    Strategy (classic macOS vibrancy):
+      * The Qt QMainWindow / central widget are translucent so Qt stops
+        painting an opaque background over the effect view.
+      * The underlying NSWindow gets opaque=NO and clearColor background.
+      * An NSVisualEffectView is inserted as the bottom-most subview of
+        the NSWindow's contentView, providing the actual blur.
+      * The native titlebar (with traffic-light buttons) keeps being
+        drawn by AppKit (titlebarAppearsTransparent stays False).
+
+    Returns True on success, False if pyobjc isn't usable or the
+    NSWindow isn't ready yet; the caller may retry.
+    """
+    if not _HAS_PYOBJC:
+        print("[AnkiBlur] pyobjc not available, skipping macOS vibrancy")
+        return False
+    try:
+        winid = window.winId()
+        if not winid:
+            return False
+        ns_view = objc.objc_object(c_void_p=int(winid))
+        ns_window = ns_view.window()
+        if ns_window is None:
+            # NSView not yet parented to an NSWindow - retry later.
+            return False
+        content_view = ns_window.contentView()
+        # Idempotent: don't stack a second NSVisualEffectView.
+        for sub in content_view.subviews():
+            if sub.isKindOfClass_(Cocoa.NSVisualEffectView):
+                ns_window.setOpaque_(False)
+                ns_window.setBackgroundColor_(Cocoa.NSColor.clearColor())
+                return True
+        bounds = content_view.bounds()
+        effect_view = Cocoa.NSVisualEffectView.alloc().initWithFrame_(bounds)
+        effect_view.setAutoresizingMask_(
+            Cocoa.NSViewWidthSizable | Cocoa.NSViewHeightSizable
+        )
+        # Classic window-background blur: reads the desktop / windows
+        # behind Anki and blurs them. WindowBackground is the standard
+        # macOS app material (subtle blur + adaptive light/dark tint).
+        # The ankiblur_background_theme addon controls the additional
+        # color overlay on top of the webview HTML.
+        effect_view.setMaterial_(
+            Cocoa.NSVisualEffectMaterialWindowBackground
+        )
+        effect_view.setBlendingMode_(
+            Cocoa.NSVisualEffectBlendingModeBehindWindow
+        )
+        effect_view.setState_(Cocoa.NSVisualEffectStateActive)
+        # Bottom-most subview so all Qt widgets render on top of it.
+        content_view.addSubview_positioned_relativeTo_(
+            effect_view, Cocoa.NSWindowBelow, None
+        )
+        # Now make the window itself transparent so the effect view is
+        # what shows through. AppKit still draws the titlebar on top.
+        ns_window.setOpaque_(False)
+        ns_window.setBackgroundColor_(Cocoa.NSColor.clearColor())
+        ns_window.setHasShadow_(True)
+        # Keep the standard titlebar (traffic lights + title) opaque.
+        try:
+            ns_window.setTitlebarAppearsTransparent_(False)
+        except Exception:
+            pass
+        print("[AnkiBlur] macOS vibrancy installed")
+        return True
+    except Exception as e:
+        import traceback
+        print(f"[AnkiBlur] vibrancy setup failed: {e}")
+        traceback.print_exc()
+        return False
+
+
+def _schedule_macos_vibrancy(window):
+    """Retry vibrancy install across a few event-loop ticks.
+
+    winId().window() can be nil very early during init; a handful of
+    QTimer retries covers the common case without blocking startup.
+    """
+    if not _HAS_PYOBJC:
+        return
+    from aqt.qt import QTimer
+    state = {"tries": 0}
+
+    def attempt():
+        if _setup_macos_vibrancy(window):
+            return
+        state["tries"] += 1
+        if state["tries"] < 10:
+            QTimer.singleShot(50, attempt)
+        else:
+            print("[AnkiBlur] giving up on vibrancy after 10 tries")
+
+    QTimer.singleShot(0, attempt)
+

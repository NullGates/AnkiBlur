diff -ruN '--exclude=Cargo.lock' '--exclude=out' '--exclude=target' original/qt/launcher/src/cleanup.rs v1_edit/qt/launcher/src/cleanup.rs
--- original/qt/launcher/src/cleanup.rs	1970-01-01 01:00:00.000000000 +0100
+++ v1_edit/qt/launcher/src/cleanup.rs	2026-07-18 00:07:26.985965670 +0200
@@ -0,0 +1,165 @@
+// AnkiBlur: one-time repair of venvs that were modified in place by the old
+// (pre-addon) site-packages text-patching scheme. Old launcher versions
+// edited aqt/main.py and aqt/webview.py inside the venv and left `.backup`
+// files beside them; the blur now lives entirely in the bundled add-on, so
+// returning users get their pristine aqt back here.
+
+use std::path::Path;
+use std::path::PathBuf;
+
+use anki_io::read_file;
+use anki_io::remove_file;
+use anki_io::write_file;
+use anki_process::CommandExt;
+use anyhow::Context;
+use anyhow::Result;
+
+/// Strings that only ever appear in files modified by the old AnkiBlur
+/// patching scheme; verified absent from pristine aqt releases.
+const MARKERS: &[&str] = &[
+    "_ankiblur_",
+    "AnkiBlur",
+    "setWindowOpacity(0.0)",
+    "Set transparent background for full transparency",
+];
+
+/// Infallible wrapper: cleanup must never block the launch.
+pub fn cleanup_legacy_patches(state: &crate::State) {
+    if let Err(e) = cleanup_inner(state) {
+        println!("Warning: AnkiBlur legacy patch cleanup failed (will retry next launch): {e:#}");
+    }
+}
+
+fn cleanup_inner(state: &crate::State) -> Result<()> {
+    let marker = state.uv_install_root.join(".ankiblur-cleanup-v1");
+    if marker.exists() {
+        return Ok(());
+    }
+    if !state.venv_folder.exists() {
+        // Nothing to repair on fresh installs.
+        write_file(&marker, "")?;
+        return Ok(());
+    }
+
+    let mut needs_reinstall = false;
+    for aqt_dir in aqt_site_dirs(state) {
+        needs_reinstall |= clean_aqt_dir(&aqt_dir)?;
+    }
+
+    if needs_reinstall {
+        crate::platform::ensure_terminal_shown()?;
+        println!(
+            "AnkiBlur: restoring pristine Anki files modified by an older AnkiBlur version..."
+        );
+        // A plain `uv sync` compares metadata, not file contents, and would
+        // leave the patched files in place - force the aqt reinstall.
+        let mut command = crate::uv_command(state)?;
+        command
+            .env("UV_CACHE_DIR", &state.uv_cache_dir)
+            .env("UV_PYTHON_INSTALL_DIR", &state.uv_python_install_dir)
+            .env(
+                "UV_HTTP_TIMEOUT",
+                std::env::var("UV_HTTP_TIMEOUT").unwrap_or_else(|_| "180".to_string()),
+            );
+        command.args(["sync", "--reinstall-package", "aqt", "--no-config"]);
+        if !state.system_qt {
+            command.arg("--managed-python");
+        }
+        if state.no_cache_marker.exists() {
+            command.env("UV_NO_CACHE", "1");
+        }
+        command.ensure_success()?;
+        println!("AnkiBlur: pristine Anki files restored.");
+    }
+
+    // Only mark complete on full success; an offline/uv failure above
+    // returns early and we retry on the next launch.
+    write_file(&marker, "")?;
+    Ok(())
+}
+
+/// All plausible site-packages/aqt dirs inside the venv, resolved
+/// dynamically (no hardcoded python version) and deduped via canonicalize
+/// (lib64 is typically a symlink to lib).
+fn aqt_site_dirs(state: &crate::State) -> Vec<PathBuf> {
+    let venv = &state.venv_folder;
+    // Windows layout.
+    let mut candidates: Vec<PathBuf> = vec![venv.join("Lib").join("site-packages")];
+    // Unix layouts: lib{,64}/python3.*/site-packages
+    for lib_name in ["lib", "lib64"] {
+        if let Ok(entries) = std::fs::read_dir(venv.join(lib_name)) {
+            for entry in entries.flatten() {
+                if entry
+                    .file_name()
+                    .to_string_lossy()
+                    .starts_with("python3")
+                {
+                    candidates.push(entry.path().join("site-packages"));
+                }
+            }
+        }
+    }
+
+    let mut seen = std::collections::HashSet::new();
+    let mut result = Vec::new();
+    for candidate in candidates {
+        let aqt_dir = candidate.join("aqt");
+        if !aqt_dir.is_dir() {
+            continue;
+        }
+        let canonical = std::fs::canonicalize(&aqt_dir).unwrap_or_else(|_| aqt_dir.clone());
+        if seen.insert(canonical) {
+            result.push(aqt_dir);
+        }
+    }
+    result
+}
+
+/// Handle `.backup` files and residual contamination in one aqt/ dir.
+/// Returns true when an aqt reinstall is required.
+fn clean_aqt_dir(aqt_dir: &Path) -> Result<bool> {
+    let mut needs_reinstall = false;
+
+    let entries = std::fs::read_dir(aqt_dir)
+        .with_context(|| format!("reading {}", aqt_dir.display()))?;
+    for entry in entries.flatten() {
+        let name = entry.file_name().to_string_lossy().to_string();
+        if !name.ends_with(".backup") {
+            continue;
+        }
+        let backup_path = entry.path();
+        let content = read_file(&backup_path)?;
+        if is_contaminated(&content) {
+            // The old patcher sometimes re-backed-up an already-patched file
+            // (double application through the lib64 symlink, or later
+            // re-syncs), so the backup itself is patched and restoring it
+            // would re-install the modifications. Discard it and reinstall.
+            println!(
+                "AnkiBlur cleanup: discarding contaminated backup {}",
+                backup_path.display()
+            );
+            needs_reinstall = true;
+        } else {
+            let target = aqt_dir.join(name.trim_end_matches(".backup"));
+            println!("AnkiBlur cleanup: restoring {}", target.display());
+            write_file(&target, &content)?;
+        }
+        remove_file(&backup_path)?;
+    }
+
+    // Files can also be contaminated without a usable backup.
+    for name in ["main.py", "webview.py"] {
+        if let Ok(content) = read_file(aqt_dir.join(name)) {
+            if is_contaminated(&content) {
+                needs_reinstall = true;
+            }
+        }
+    }
+
+    Ok(needs_reinstall)
+}
+
+fn is_contaminated(content: &[u8]) -> bool {
+    let text = String::from_utf8_lossy(content);
+    MARKERS.iter().any(|marker| text.contains(marker))
+}

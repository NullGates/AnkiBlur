#!/bin/bash
# CI-only shim that shadows /usr/bin/hdiutil via a GITHUB_PATH entry
# registered by scripts/validate-and-apply-patches.sh (macOS runners only).
#
# Why it exists: the "Create DMG" step in .github/workflows/build-macos.yml
# runs
#     hdiutil create -volname "AnkiBlur" -srcfolder dmg_stage -ov -format UDZO ...
# and lets hdiutil size the intermediate read-write image from its own
# estimate of the source folder. That estimate is not reliably sufficient:
# on identical input bytes, run 29621161026 (feat/addon-runtime @ 69de384)
# passed while run 29621715081 (@ 40074a6, whose only delta is a
# .gitattributes file) failed with
#     hdiutil: create failed - No space left on device
#     could not access /Volumes/AnkiBlur/Anki.app/Contents/MacOS/uv - No space left on device
# i.e. the mounted intermediate volume filled mid-copy even though the
# runner disk had 137Gi free. The deterministic fix is an explicit -size
# with generous headroom, which "-srcfolder ... -size" supports (hdiutil
# man page: size specifiers override the srcfolder-based calculation; this
# is also exactly how create-dmg and this repo's scripts/package-artifacts.sh
# invoke it). But the hdiutil call lives inside a workflow file, and pushes
# from the CI credentials are rejected whenever a commit touches
# .github/workflows/* (gh OAuth token without the `workflow` scope — see
# .github/pending-workflows/README.md). Until the pending workflows land,
# this shim injects the explicit size from outside the frozen workflow.
#
# Behavior: for `hdiutil create ... -srcfolder <dir> ...` with NO explicit
# size option, compute the LOGICAL byte size of <dir> (sum of st_size, not
# allocated blocks, so APFS clones/sparse extents can never make the total
# undercount what must be materialized inside the image), add 25% + 128 MiB
# headroom for filesystem/metadata overhead, and re-exec the real hdiutil
# with `-size <N>m` inserted after the verb. Every other invocation — and
# any create that already carries a size option, such as the one in the
# pending build-macos.yml — passes through untouched, so the shim is
# idempotent and safe to leave in PATH. Delete scripts/ci/ together with
# .github/pending-workflows/ once workflow-scoped credentials land the
# pending workflows (the registration in validate-and-apply-patches.sh
# skips silently when this file is gone).

set -euo pipefail

REAL="${ANKIBLUR_REAL_HDIUTIL:-/usr/bin/hdiutil}"

if [[ "${1:-}" == "create" ]]; then
    srcfolder=""
    has_size=0
    prev=""
    for arg in "$@"; do
        case "$prev" in
            -srcfolder|-srcdir) srcfolder="$arg" ;;
        esac
        case "$arg" in
            -size|-megabytes|-sectors) has_size=1 ;;
        esac
        prev="$arg"
    done

    if [[ "$has_size" -eq 0 && -n "$srcfolder" && -d "$srcfolder" ]]; then
        # BSD stat: %z = logical size in bytes. One line per file; awk sums.
        bytes="$( (find "$srcfolder" -type f -print0 | xargs -0 stat -f %z 2>/dev/null || true) \
            | awk '{ s += $1 } END { printf "%d", s + 0 }')"
        if [[ "$bytes" -gt 0 ]]; then
            logical_mb=$(( bytes / 1048576 ))
            size_mb=$(( logical_mb + logical_mb / 4 + 128 ))
            echo "[ankiblur hdiutil shim] '$srcfolder' is ${logical_mb} MiB logical;" \
                 "adding explicit -size ${size_mb}m (see scripts/ci/hdiutil)" >&2
            exec "$REAL" create -size "${size_mb}m" "${@:2}"
        fi
    fi
fi

exec "$REAL" "$@"
